{
  "entryPoints": ["src/main.tsx"],
  "out": "docs/api",
  "exclude": [
    "**/__tests__/**/*",
    "**/*.test.*",
    "**/test-*.ts",
    "**/vitest.*.ts"
  ],
  "excludePrivate": true,
  "excludeInternal": true,
  "readme": "README.md",
  "plugin": ["typedoc-plugin-markdown"],
  "theme": "default",
  "name": "Claude Code Test - API Documentation",
  "includeVersion": true
}
